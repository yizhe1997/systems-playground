PORT=8088
REDIS_ADDR=localhost:6385
POSTGRES_URL=postgres://postgres:postgres@localhost:5435/futures_copilot?sslmode=disable
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OpenRouter provider routing (docs: provider.only)
# Global lock (applies to all OpenRouter requests):
# OPENROUTER_PROVIDER_ONLY=google-ai-studio
# Scoped lock (only for Google/Gemma/Gemini model slugs):
# OPENROUTER_PROVIDER_ONLY_GOOGLE_MODELS=google-ai-studio
# Optional: true/false (default: OpenRouter default behavior)
# OPENROUTER_PROVIDER_ALLOW_FALLBACKS=false
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
INTERNAL_API_SHARED_SECRET=replace_with_the_same_secret_used_by_frontend
MOCK_AI=true

# Contact endpoint (server-side only)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_EMAIL=your_smtp_login_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="Futures Copilot <no-reply@example.com>"
CONTACT_INBOX_EMAIL=you@example.com

# reCAPTCHA v3 verification (server-side secret + policy)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_EXPECTED_HOSTNAME=localhost

# Contact API rate limiting
CONTACT_RATE_LIMIT_WINDOW_MS=600000
CONTACT_RATE_LIMIT_MAX_REQUESTS=5
