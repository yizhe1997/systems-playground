PORT=8088
REDIS_ADDR=localhost:6385
POSTGRES_URL=postgres://postgres:postgres@localhost:5435/futures_copilot?sslmode=disable
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OpenRouter provider routing (docs: provider.only)
# Global lock (applies to all OpenRouter requests):
# OPENROUTER_PROVIDER_ONLY=google-ai-studio
# Scoped lock (only for Google/Gemma/Gemini model slugs):
# OPENROUTER_PROVIDER_ONLY_GOOGLE_MODELS=google-ai-studio
# Optional: true/false (default: OpenRouter default behavior)
# OPENROUTER_PROVIDER_ALLOW_FALLBACKS=false
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
INTERNAL_API_SHARED_SECRET=replace_with_the_same_secret_used_by_frontend
MOCK_AI=true
