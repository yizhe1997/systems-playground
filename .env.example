# Docker Registry Username used by docker-compose.override.yml (production)
DOCKER_USERNAME=yourdockerhub

# Resume Email Integration (Google App Password)
SMTP_EMAIL=your.email@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# Optional Discord Webhook for instant notification when someone requests a resume
RESUME_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Filebrowser Configuration (for generating secure PDF links and CMS file hosting)
FILEBROWSER_PUBLIC_URL=https://files.yourdomain.com
FILEBROWSER_ADMIN_USERNAME=admin
FILEBROWSER_ADMIN_PASSWORD=admin
