# Directory for this layer's own startup log files (defaults to $SCRIPT_DIR/logs if unset, which
# equals $APP_BASE_DIR/logs once deployed). Not wired to a GitHub var — deploy-app-scripts.yml
# never writes this line, CI always leaves it unset. Only relevant if you hand-edit the deployed
# .env on the host directly, which nobody needs to do. (Purely this script's own log output, e.g.
# wsl-startup.log — not container/app logs.)
APP_LOG_DIR="/home/user/apps/logs"

# Discord webhook URL for app-service startup failure alerts (leave empty to disable). Reuses the
# same webhook as the infra layer — no separate secret needed.
DISCORD_WEBHOOK_INFRA_ALERTS="https://discord.com/api/webhooks/..."
