# Environment variables for Observability.
# Copy to .env on the host and fill in real values — .env is gitignored, this file is not.
# On deploy, these come from Infisical instead (see deploy-infra-observability.yml) — this file
# is only needed if you're running `docker compose up` locally by hand.

# Required, no default — fails loud if missing, matching this repo's convention for anything
# security-sensitive (e.g. REGISTRY_HOST/REGISTRY_USERNAME/REGISTRY_PASSWORD).
GRAFANA_ADMIN_PASSWORD=

# How long Prometheus keeps metrics locally before evicting old data. Loki's own retention is
# set directly in loki-config.yaml (currently 14 days, matching this repo's existing
# BACKUP_RETENTION_DAYS default elsewhere) rather than via env var, to keep it simple — change
# there if you want a different log retention window.
PROMETHEUS_RETENTION=15d
