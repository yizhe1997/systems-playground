# Directory for this layer's own startup/backup log files (defaults to $SCRIPT_DIR/logs if
# unset, which equals $INFRA_BASE_DIR/logs once deployed). Not wired to a GitHub var —
# deploy-infra-scripts.yml never writes this line, CI always leaves it unset. Only relevant if
# you hand-edit the deployed .env on the host directly, which nobody needs to do. (Purely the
# scripts' own log output, e.g. wsl-startup.log/wsl-backup.log — not container/app logs.)
INFRA_LOG_DIR="/home/user/infra/logs"

# Path to the cloudflared log file
CLOUDFLARED_LOG_DIR="/home/user/.cloudflared/cloudflared.log"

# Cloudflare tunnel name — must match the name from: cloudflared tunnel list
TUNNEL_NAME="tunnel"

# Discord webhook URL for Cloudflare tunnel failure alerts (leave empty to disable)
DISCORD_WEBHOOK_INFRA_ALERTS="https://discord.com/api/webhooks/..."

# Directory backups are written to, one timestamped subfolder per run (defaults to
# $SCRIPT_DIR/../backups if unset)
BACKUP_DIR="/home/user/backups"

# How many days of backup runs to keep before wsl-backup.sh prunes older ones (defaults to 14)
BACKUP_RETENTION_DAYS="14"
