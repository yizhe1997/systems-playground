# Directory for startup log files (defaults to $SCRIPT_DIR/logs if unset)
LOGDIR="/home/user/infra/logs"

# Path to the cloudflared log file
CFLOG="/home/user/.cloudflared/cloudflared.log"

# Cloudflare tunnel name — must match the name from: cloudflared tunnel list
TUNNEL_NAME="tunnel"

# Discord webhook URL for Cloudflare tunnel failure alerts (leave empty to disable)
DISCORD_WEBHOOK_INFRA_ALERTS="https://discord.com/api/webhooks/..."
