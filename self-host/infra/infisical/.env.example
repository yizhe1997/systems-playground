# Bootstrap environment for the Infisical instance itself.
# Copy to .env on the host and fill in real values — .env is gitignored, this file is not.
#
# IMPORTANT: these are Infisical's OWN bootstrap secrets (its root of trust). They cannot live
# inside Infisical — that's a chicken-and-egg problem every secrets manager has. They stay as a
# plaintext .env on the runner host, same as everything else does today. Everything ELSE (SMTP
# creds, NextAuth secret, Docker Hub creds, etc.) is what moves OUT of plaintext .env files and
# into Infisical once this is running — see docs/adrs/002-infisical-secret-injection.md.

# --- Postgres (dedicated instance, not shared) ---
POSTGRES_USER=infisical
POSTGRES_PASSWORD=
POSTGRES_DB=infisical
DB_CONNECTION_URI=postgres://infisical:<same-password-as-above>@db:5432/infisical

# --- Redis (dedicated instance, not shared) ---
REDIS_URL=redis://redis:6379

# --- Infisical core secrets ---
# ENCRYPTION_KEY: 32-byte hex string. Generate with: openssl rand -hex 16
ENCRYPTION_KEY=
# AUTH_SECRET: used to sign JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=
# SITE_URL: the URL you'll actually reach this at — internal IP:port if kept internal-only,
# or the public hostname if exposed via Cloudflare Tunnel + Access. No trailing slash.
SITE_URL=http://localhost:8090
