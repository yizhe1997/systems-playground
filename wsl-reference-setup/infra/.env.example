# Logging paths for WSL startup
LOGDIR="/home/user/infra/logs"
CFLOG="/home/user/.cloudflared/cloudflared.log"

# Space-separated list of infrastructure directories to boot
APPS_LIST="/home/user/infra/uptime-kuma"

# Discord webhook URL for cloudflare tunnel failure alerts
DISCORD_WEBHOOK="https://discord.com/api/webhooks/..."