# ==========================================================
# config.env (Example)
# Rename this file to config.env to securely override paths.
# Do NOT commit config.env to Git!
# ==========================================================

# Path to the systems-playground repository on your host
# APP_DIR="/home/user/apps/systems-playground"

# Logging paths for WSL startup
# LOGDIR="/home/user/apps/logs"

# Space-separated list of directories to boot on WSL startup
# APPS_LIST="/home/user/apps/systems-playground /home/user/apps/n8n"

# --- Backup Configuration ---
# Directory to store the .tar.gz backups
# BACKUP_BASE_DIR="/home/user/apps/backups"

# Number of days to keep backups before deleting them
# BACKUP_RETENTION_DAYS=7

# Space-separated list of Docker volumes to back up (e.g., the volume names in 'docker volume ls')
# VOLUMES_TO_BACKUP="systems-playground_redis_data systems-playground_rabbitmq_data n8n_data"